{
    "version": 2,
    "installCommand": "npm ci",
    "buildCommand": "cd frontend-angular && npm ci && npm run build",
    "outputDirectory": "frontend-angular/dist/m1p13mean-Isaia-Toky/browser",
    "routes": [
        {
            "src": "/api/(.*)",
            "dest": "/api/index.js"
        },
        {
            "handle": "filesystem"
        },
        {
            "src": "/(.*)",
            "dest": "/index.html"
        }
    ]
}